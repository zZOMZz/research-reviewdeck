{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@reviewdeck/shared": ["packages/shared/src/index.ts"]
    }
  },
  "include": ["packages/core/src/**/*.ts", "packages/shared/src/**/*.ts"]
}
